{% extends "base.html" %}
{% block title %}Mi Perfil — EduTranscribe{% endblock %}

{% block content %}
<div class="dash-layout">
  <aside class="sidebar sidebar-doc">
    <div class="sidebar-logo">
      <div class="nav-logo-mark"><svg viewBox="0 0 18 18" fill="none"><path d="M2 9h2M5 5h2M5 13h2M9 3h2M9 15h2M13 6h2M13 12h2" stroke="white" stroke-width="1.8" stroke-linecap="round"/></svg></div>
      <span class="sidebar-logo-text">EduTranscribe</span>
    </div>
    <div class="sidebar-user">
      <div class="sidebar-avatar sidebar-avatar-doc">{{ nombre[:2].upper() }}</div>
      <div><div class="sidebar-user-name">{{ nombre }}</div><div class="sidebar-user-role sidebar-role-doc">Docente</div></div>
    </div>
    <nav class="sidebar-nav">
      <span class="sidebar-nav-section">Principal</span>
      <a class="sidebar-nav-item" href="{{ url_for('docente_dashboard') }}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>Resumen
      </a>
      <a class="sidebar-nav-item" href="{{ url_for('docente_nueva_clase') }}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2C10.3 2 9 3.3 9 5v7c0 1.7 1.3 3 3 3s3-1.3 3-3V5c0-1.7-1.3-3-3-3z"/><path d="M19 10v2a7 7 0 01-14 0v-2"/><line x1="12" y1="19" x2="12" y2="22"/></svg>Nueva clase
      </a>
      <span class="sidebar-nav-section">Gestión</span>
      <a class="sidebar-nav-item" href="{{ url_for('docente_nueva_clase') }}#biblioteca">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/></svg>Mis clases
      </a>
      <a class="sidebar-nav-item" href="{{ url_for('docente_estadisticas') }}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polyline points="22,12 18,12 15,21 9,3 6,12 2,12"/></svg>Estadísticas
      </a>
      <span class="sidebar-nav-section">Cuenta</span>
      <a class="sidebar-nav-item active-doc" href="{{ url_for('docente_perfil') }}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>Perfil
      </a>
    </nav>
    <div class="sidebar-footer">
      <form method="POST" action="{{ url_for('api_logout') }}" style="margin:0;">
        <button type="submit" class="sidebar-nav-item" style="color:rgba(246,241,231,.5);">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="18" height="18"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16,17 21,12 16,7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>Cerrar sesión
        </button>
      </form>
    </div>
  </aside>

  <main class="dash-main dash-main-doc">
    <div class="dash-topbar">
      <span class="dash-topbar-title">Mi perfil</span>
    </div>

    <div class="dash-content" style="max-width:600px;">

      <!-- Avatar section -->
      <div style="background:var(--white);border-radius:var(--radius-xl);border:1px solid var(--cream-2);padding:32px;margin-bottom:24px;display:flex;align-items:center;gap:24px;">
        <div style="width:72px;height:72px;border-radius:50%;background:var(--gold);display:flex;align-items:center;justify-content:center;font-family:var(--serif);font-size:28px;font-weight:700;color:white;flex-shrink:0;">
          {{ nombre[:2].upper() }}
        </div>
        <div>
          <div style="font-family:var(--serif);font-size:22px;font-weight:600;color:var(--ink);margin-bottom:4px;">{{ nombre }}</div>
          <div style="font-size:13px;color:var(--ink-3);">{{ email }}</div>
          <div style="margin-top:8px;">
            <span style="display:inline-block;background:#E8F5EF;color:#0D3B2E;font-size:11px;font-weight:700;padding:3px 10px;border-radius:20px;letter-spacing:.04em;text-transform:uppercase;">Docente</span>
          </div>
        </div>
      </div>

      <!-- Edit form -->
      <div style="background:var(--white);border-radius:var(--radius-xl);border:1px solid var(--cream-2);padding:32px;">
        <h3 style="font-family:var(--serif);font-size:20px;font-weight:600;color:var(--ink);margin-bottom:24px;">Editar información</h3>

        <div class="alert alert-error" id="perfilAlert"></div>
        <div class="alert alert-success" id="perfilSuccess"></div>

        <form class="auth-form" id="perfilForm">
          <div class="form-group">
            <label>Nombre completo</label>
            <input type="text" class="form-input" id="pNombre" value="{{ nombre }}" required>
          </div>
          <div class="form-group">
            <label>Correo electrónico</label>
            <input type="email" class="form-input" value="{{ email }}" disabled
              style="background:var(--cream);color:var(--ink-3);cursor:not-allowed;">
            <span style="font-size:11px;color:var(--ink-3);margin-top:4px;">El correo no se puede cambiar</span>
          </div>
          <div class="form-group">
            <label>Institución</label>
            <input type="text" class="form-input" id="pInstitucion" value="{{ institucion }}" placeholder="Ej: ULEAM El Carmen">
          </div>

          <div style="border-top:1px solid var(--cream-2);padding-top:20px;margin-top:4px;">
            <div style="font-size:13px;font-weight:600;color:var(--ink-2);margin-bottom:16px;">Cambiar contraseña <span style="font-weight:400;color:var(--ink-3)">(opcional)</span></div>
            <div class="form-group">
              <label>Nueva contraseña</label>
              <input type="password" class="form-input" id="pPassword" placeholder="Mínimo 8 caracteres"
                oninput="updatePassStrength(this.value)">
              <div class="pass-strength">
                <div class="pass-bar" id="pbar1"></div>
                <div class="pass-bar" id="pbar2"></div>
                <div class="pass-bar" id="pbar3"></div>
                <div class="pass-bar" id="pbar4"></div>
              </div>
            </div>
          </div>

          <button type="submit" class="btn btn-primary btn-lg" id="perfilBtn">Guardar cambios</button>
        </form>
      </div>

    </div>
  </main>
</div>
{% endblock %}

{% block extra_js %}
<script>
function updatePassStrength(val) {
  const bars=['pbar1','pbar2','pbar3','pbar4'];
  bars.forEach(b=>document.getElementById(b).className='pass-bar');
  let s=0;
  if(val.length>=8) s++;
  if(val.length>=12) s++;
  if(/[A-Z]/.test(val)&&/[0-9]/.test(val)) s++;
  if(/[^A-Za-z0-9]/.test(val)) s++;
  const cls=s<=1?'weak':s<=2?'medium':'strong';
  for(let i=0;i<Math.min(s+1,4);i++) document.getElementById(bars[i]).className=`pass-bar ${cls}`;
}

document.getElementById('perfilForm').addEventListener('submit', async(e)=>{
  e.preventDefault();
  const btn=document.getElementById('perfilBtn'); btn.disabled=true; btn.textContent='Guardando…';
  const alertErr=document.getElementById('perfilAlert');
  const alertOk =document.getElementById('perfilSuccess');
  alertErr.classList.remove('show'); alertOk.classList.remove('show');

  const payload={
    nombre:      document.getElementById('pNombre').value.trim(),
    institucion: document.getElementById('pInstitucion').value.trim(),
    password:    document.getElementById('pPassword').value,
  };

  const res  = await fetch('/api/perfil',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
  const data = await res.json();

  if(data.success){
    alertOk.textContent='Perfil actualizado correctamente'; alertOk.classList.add('show');
    showToast('Perfil actualizado','success');
    document.getElementById('pPassword').value='';
    ['pbar1','pbar2','pbar3','pbar4'].forEach(b=>document.getElementById(b).className='pass-bar');
  } else {
    alertErr.textContent=data.error||'Error al guardar'; alertErr.classList.add('show');
  }
  btn.disabled=false; btn.textContent='Guardar cambios';
});
</script>
{% endblock %}